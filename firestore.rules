rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Users
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['email']) && data.email is string && data.email.size() <= 200;
      }
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if isSignedIn() && resource.data.id == request.auth.uid; // id is not typically the uid, but backend uses custom auth!
      // Actually backend uses its own uuid. But we can just use userId.
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
    }

    // Sessions
    match /sessions/{sessionId} {
      function isValidSession(data) {
        return data.keys().hasAll(['user_id']) && data.user_id is string;
      }
      allow read: if isSignedIn() && existing().user_id == request.auth.uid;
      allow create: if isSignedIn() && incoming().user_id == request.auth.uid && isValidSession(incoming());
      allow update: if isSignedIn() && existing().user_id == request.auth.uid && incoming().user_id == request.auth.uid && isValidSession(incoming());
      allow delete: if isSignedIn() && existing().user_id == request.auth.uid;
    }

    // Journals
    match /journals/{journalId} {
      function isValidJournal(data) {
        return data.keys().hasAll(['user_id', 'title', 'content', 'date']) && data.user_id is string && data.title is string && data.content is string && data.date is string;
      }
      allow read: if isSignedIn() && existing().user_id == request.auth.uid;
      allow create: if isSignedIn() && incoming().user_id == request.auth.uid && isValidJournal(incoming());
      allow update: if isSignedIn() && existing().user_id == request.auth.uid && incoming().user_id == request.auth.uid && isValidJournal(incoming());
      allow delete: if isSignedIn() && existing().user_id == request.auth.uid;
    }

    // Goals
    match /goals/{goalId} {
      function isValidGoal(data) {
        return data.keys().hasAll(['user_id', 'title']) && data.user_id is string && data.title is string;
      }
      allow read: if isSignedIn() && existing().user_id == request.auth.uid;
      allow create: if isSignedIn() && incoming().user_id == request.auth.uid && isValidGoal(incoming());
      allow update: if isSignedIn() && existing().user_id == request.auth.uid && incoming().user_id == request.auth.uid && isValidGoal(incoming());
      allow delete: if isSignedIn() && existing().user_id == request.auth.uid;
    }

    // Habits
    match /habits/{habitId} {
      function isValidHabit(data) {
        return data.keys().hasAll(['user_id']) && data.user_id is string;
      }
      allow read: if isSignedIn() && existing().user_id == request.auth.uid;
      allow create: if isSignedIn() && incoming().user_id == request.auth.uid && isValidHabit(incoming());
      allow update: if isSignedIn() && existing().user_id == request.auth.uid && incoming().user_id == request.auth.uid && isValidHabit(incoming());
      allow delete: if isSignedIn() && existing().user_id == request.auth.uid;
    }

    // Badges
    match /badges/{badgeId} {
      function isValidBadge(data) {
        return data.keys().hasAll(['user_id']) && data.user_id is string;
      }
      allow read: if isSignedIn() && existing().user_id == request.auth.uid;
      allow create: if isSignedIn() && incoming().user_id == request.auth.uid && isValidBadge(incoming());
      allow update: if isSignedIn() && existing().user_id == request.auth.uid && incoming().user_id == request.auth.uid && isValidBadge(incoming());
      allow delete: if isSignedIn() && existing().user_id == request.auth.uid;
    }

    // Voice Recordings
    match /voice_recordings/{recordingId} {
      function isValidRecording(data) {
        return data.keys().hasAll(['user_id']) && data.user_id is string;
      }
      allow read: if isSignedIn() && existing().user_id == request.auth.uid;
      allow create: if isSignedIn() && incoming().user_id == request.auth.uid && isValidRecording(incoming());
      allow update: if isSignedIn() && existing().user_id == request.auth.uid && incoming().user_id == request.auth.uid && isValidRecording(incoming());
      allow delete: if isSignedIn() && existing().user_id == request.auth.uid;
    }
  }
}
